{
  "name": "@yk-pets/pet-extension-runtime",
  "version": "0.7.8",
  "description": "Site-aware YK Pets extension host with adaptive rendering, lifecycle suspension, split analysis/remediation/repository bundles, and independently authorized lazy remote collaboration.",
