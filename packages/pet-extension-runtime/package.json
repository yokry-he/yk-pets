    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@yk-pets/pet-feature-loader": "0.7.8",
    "@yk-pets/pet-runtime-adaptive": "0.7.8",
    "@yk-pets/pet-runtime-lifecycle": "0.7.8",
    "@yk-pets/pet-site-policy": "0.7.8"
  }
}
