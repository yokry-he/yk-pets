{
  "name": "@nova/local-agent",
  "version": "0.1.2",
  "description": "YK-PETS Local Agent. The legacy @nova workspace scope is retained for v0.6.10 compatibility.",
  "private": true,
  "type": "module",
  "bin": {
    "yk-pets-agent": "./dist/cli.js",
    "nova-agent": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@nova/shared": "workspace:*",
    "commander": "15.0.0",
    "diff": "8.0.0",
    "fast-glob": "3.3.3",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/ws": "8.18.1",
    "tsup": "8.5.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
