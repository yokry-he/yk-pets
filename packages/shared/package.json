{
  "name": "@nova/shared",
  "version": "0.1.2",
  "description": "Shared YK-PETS brand, pet identity, audit, network, memory, and runtime contracts. The @nova scope is retained for workspace compatibility.",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./audit": "./src/audit.ts",
    "./brand": "./src/brand.ts",
    "./messages": "./src/messages.ts",
    "./protocol": "./src/protocol.ts",
    "./network": "./src/network.ts",
    "./pet-memory": "./src/pet-memory.ts",
    "./pet-memory-navigation": "./src/pet-memory-navigation.ts"
  },
  "types": "./src/index.ts",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
