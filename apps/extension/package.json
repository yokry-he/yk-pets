{
  "name": "@nova/extension",
  "version": "0.6.10",
  "description": "YK-PETS Browser Agent extension featuring Zeph, the Cloud Fox. The @nova scope is retained for workspace compatibility.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt -b chrome",
    "build": "wxt build -b chrome",
    "zip": "wxt zip -b chrome",
    "prepare": "wxt prepare",
    "typecheck": "wxt prepare && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nova/shared": "workspace:*",
    "@yk-pets/pet-core": "workspace:*",
    "@yk-pets/pet-vue-adapter": "workspace:*",
    "@yk-pets/pet-web-component": "workspace:*",
    "@tresjs/core": "5.8.3",
    "three": "0.185.1",
    "vue": "3.5.40"
  },
  "devDependencies": {
    "@types/three": "0.185.0",
    "@wxt-dev/module-vue": "1.0.3",
    "typescript": "5.9.3",
    "vue-tsc": "3.3.7",
    "wxt": "0.20.27",
    "@types/chrome": "0.2.2"
  }
}
