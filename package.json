{
  "name": "yk-pets",
  "version": "0.7.8",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "node scripts/build.mjs",
    "test": "node --experimental-strip-types --test --test-concurrency=4 packages/*/test/*.test.ts",
    "check": "node --experimental-strip-types scripts/check-release.ts",
    "validate": "npm run clean && npm run build && npm test && npm run check",
    "pack:sdk": "node scripts/pack.mjs",
    "smoke:packages": "node scripts/smoke-packages.mjs",
    "release:verify": "npm run validate && npm run pack:sdk && npm run smoke:packages"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "5.8.3"
  }
}
